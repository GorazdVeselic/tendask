<!-- Notification status-bar icon (Tendask logomark: hexagon + leaf), white so
     the system can tint it. A density-INDEPENDENT vector on purpose: density-
     qualified PNGs put the resource entry only in a density config split, whose
     resources.arsc is not in the base on SplitCompat-less installs (Play
     pre-launch / Test Lab) -> getIdentifier returns 0 -> invalid_icon at init.
     A single vector lands in the base resources.arsc, always loaded everywhere. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="120"
    android:viewportHeight="120">
    <path
        android:pathData="M60,8 L106,34 L106,86 L60,112 L14,86 L14,34 Z"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="5"
        android:strokeLineJoin="round" />
    <path
        android:pathData="M60,30 C39,40 35,68 49,88 C57,75 76,69 84,46 C72,50 59,56 53,69 C53,53 55,40 60,30 Z"
        android:fillColor="#FFFFFFFF" />
</vector>
