# Claude Code (local, machine-specific permissions)
.claude/settings.local.json

# Temporary / scratch outputs + screenshots (CLAUDE.md konvencija: gredo v tmp/)
/tmp/
# `flutter screenshot` saves flutter_NN.png in the repo root by default
/flutter_*.png

# Local-only working docs (runbooks, session handoffs) — durable state lives in
# memory/CLAUDE.md/roadmap, not here. `*.local.md` is the convention for these.
*.local.md
/docs/m11/handoff-next-session.md

# Local secrets — nikoli v repo (CLAUDE.md). Predloge (*.example.json) SMEJO v git.
/dart_defines.json
/dart_defines.staging.json
.env
# Firebase config (vsebuje projektne ključe) — nikoli v repo; gradle ga bere lokalno
/android/app/google-services.json

# Osebni podatki tretjih oseb (GDPR) — seznami testerjev z e-naslovi nikoli v repo
/docs/go-live/testers.md
/docs/go-live/testers.csv

# Android release signing — keystore + gesla nikoli v repo (CLAUDE.md)
/android/key.properties
*.jks
*.keystore

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
devtools_options.yaml
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
